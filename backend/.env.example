DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_FRONTEND_ORIGIN=https://bunge-mkononi.vercel.app
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Override this if your frontend uses a different origin.
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Set to 1 only if you want the app to run migrations and collectstatic on startup outside Render.
DJANGO_BOOTSTRAP_ON_STARTUP=0

DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=bunge_mkononi
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=postgres
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432

# Africa's Talking SMS broadcaster
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SHORT_CODE=
AFRICASTALKING_SMS_TIMEOUT=20

# Optional PDF document processing / OCR
# Install OCRmyPDF and its local OCR dependencies on the host if you want scanned PDFs to be searchable.
PDF_TEXT_MIN_WORDS=80

# Optional SQLite fallback for quick throwaway testing:
# DJANGO_DB_ENGINE=django.db.backends.sqlite3
# DJANGO_DB_NAME=db.sqlite3
